        {
          "editorMode": "code",
          "expr": "100 * sum(rate(noapp_http_server_request_count_total{http_route=~\"$route\", http_response_status_code=~\"[45]..\"}[$__rate_interval])) / clamp_min(sum(rate(noapp_http_server_request_count_total{http_route=~\"$route\"}[$__rate_interval])), 0.000000001)",
          "legendFormat": "Errors",
          "range": true,
          "refId": "B"
        }
